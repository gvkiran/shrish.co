rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'contact@shrish.co';
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function newOrderCustomerIsValid() {
      return !request.resource.data.keys().hasAny(['customerUid'])
        || (
          isSignedIn()
          && request.resource.data.customerUid == request.auth.uid
        );
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /user_profiles/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if newOrderCustomerIsValid();
      allow get: if isAdmin()
        || (
          isSignedIn()
          && resource.data.customerUid == request.auth.uid
        );
      allow list: if isAdmin()
        || (
          isSignedIn()
          && resource.data.customerUid == request.auth.uid
        );
      allow update, delete: if isAdmin();
    }

    match /order_feedback/{feedbackId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if false;
    }

    match /refund_requests/{docId} {
      allow get, list: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /promo_codes/{code} {
      allow get: if true;                             // customers validate a code at checkout
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();     // usedCount is bumped by Cloud Functions (admin SDK)
    }

    match /promo_redemptions/{id} {
      allow get: if true;                             // client can check "already used" for its own code+phone
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();     // written by Cloud Functions only
    }

    match /order_locks/{phoneDigits} {
      allow get: if true;
      allow list: if false;
      allow create: if true;
      allow update: if isAdmin()
        || (
          request.resource.data.status == 'pending'
          && request.resource.data.phoneDigits == phoneDigits
        );
      allow delete: if isAdmin();
    }

    match /notify_requests/{docId} {
      allow get: if true;
      allow create: if true;
      allow list, update, delete: if isAdmin();
    }

    match /email_subscribers/{emailId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /accounting_batches/{batchId} {
      allow get, list, create, update, delete: if isAdmin();
    }
  }
}
